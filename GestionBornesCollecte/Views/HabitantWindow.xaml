<Window x:Class="GestionBornesCollecte.Views.HabitantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GestionBornesCollecte.Converters"
        Title="Habitant - Bornes de collecte"
        Height="560" Width="950"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:NiveauToColorConverter x:Key="NiveauToColor"/>
    </Window.Resources>

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Background="#4CAF50" Height="45">
            <Button Content="← Retour" Width="90" Margin="8,6,0,6"
                    Background="White" Foreground="#4CAF50"
                    BorderThickness="0" FontWeight="Bold"
                    Click="BtnRetour_Click"/>
            <TextBlock Text="Vue Habitant — Bornes près de chez vous"
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,8,10,8">
            <TextBox x:Name="txtRecherche"
                     Width="220" Height="32" Padding="6" Margin="0,0,8,0"
                     TextChanged="txtRecherche_TextChanged"/>
            <TextBlock Text="🔍 Recherche par nom ou adresse"
                       VerticalAlignment="Center" Foreground="#888" Margin="0,0,20,0"/>
            <Button Content="Toutes les bornes" Width="140" Height="32"
                    Margin="0,0,10,0" Click="BtnToutes_Click"/>
            <Button Content="★ Mes favoris" Width="120" Height="32"
                    Background="#FFC107" BorderThickness="0"
                    Click="BtnFavoris_Click"/>
        </StackPanel>

        <Grid Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="lstBornes" Grid.Column="0"
                      SelectionChanged="lstBornes_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"
                                Value="{Binding NiveauRemplissage,
                                Converter={StaticResource NiveauToColor}}"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Id" Width="40"
                                        DisplayMemberBinding="{Binding IdBorne}"/>
                        <GridViewColumn Header="Nom" Width="150"
                                        DisplayMemberBinding="{Binding Nom}"/>
                        <GridViewColumn Header="%" Width="50"
                                        DisplayMemberBinding="{Binding NiveauRemplissage}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Border Grid.Column="1" Margin="10,0,0,0" Padding="15"
                    BorderThickness="1" BorderBrush="#AAAAAA" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Détails de la borne"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

                    <TextBlock x:Name="txtNom"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtAdresse" Margin="0,4,0,0"/>
                    <TextBlock x:Name="txtNiveau" Margin="0,8,0,0"/>

                    <Border x:Name="borderAlerte"
                            Margin="0,12,0,12" Padding="8"
                            Background="#FFEBEE" CornerRadius="4"
                            Visibility="Collapsed">
                        <TextBlock Text="⚠ Cette borne est presque pleine !"
                                   Foreground="Red" FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="btnFavori"
                            Content="☆ Ajouter aux favoris"
                            Width="180" Height="34"
                            HorizontalAlignment="Left"
                            Background="#FFC107" BorderThickness="0"
                            Click="BtnToggleFavori_Click"/>
                </StackPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>