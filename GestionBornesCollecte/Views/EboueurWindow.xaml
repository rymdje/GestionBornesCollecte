<Window x:Class="GestionBornesCollecte.Views.EboueurWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GestionBornesCollecte.Converters"
        Title="Éboueur - Bornes de collecte"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:NiveauToColorConverter x:Key="NiveauToColor"/>
    </Window.Resources>

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Background="#FF9800" Height="45">
            <Button Content="← Retour" Width="90" Margin="8,6,0,6"
                    Background="White" Foreground="#FF9800"
                    BorderThickness="0" FontWeight="Bold"
                    Click="BtnRetour_Click"/>
            <TextBlock Text="Vue Éboueur — Agent de collecte"
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,8,0,8">
            <Button Content="Top 10 pleines" Width="140" Height="32"
                    Margin="0,0,10,0" Click="BtnTop10_Click"/>
            <Button Content="Toutes les bornes" Width="140" Height="32"
                    Margin="0,0,10,0" Click="BtnToutes_Click"/>
            <Button Content="✔ Marquer comme vidée" Width="180" Height="32"
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Click="BtnMarquerVidee_Click"/>
        </StackPanel>

        <Grid Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0" x:Name="lstBornes"
                      SelectionChanged="lstBornes_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"
                                Value="{Binding NiveauRemplissage,
                                Converter={StaticResource NiveauToColor}}"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Id" Width="40"
                                        DisplayMemberBinding="{Binding IdBorne}"/>
                        <GridViewColumn Header="Nom" Width="150"
                                        DisplayMemberBinding="{Binding Nom}"/>
                        <GridViewColumn Header="%" Width="60"
                                        DisplayMemberBinding="{Binding NiveauRemplissage}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Border Grid.Column="1" Margin="10,0,0,0" Padding="15"
                    BorderThickness="1" BorderBrush="#AAAAAA" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Détails de la borne"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock x:Name="txtNom"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtAdresse" Margin="0,4,0,0"/>
                    <TextBlock x:Name="txtNiveau" Margin="0,8,0,0"/>
                    <TextBlock x:Name="txtAlerte"
                               Text="⚠ PRIORITÉ : borne à vider !"
                               Foreground="Red" FontWeight="Bold"
                               Margin="0,12,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>