<Window x:Class="GestionBornesCollecte.Views.GestionnaireWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GestionBornesCollecte.Converters"
        Title="Gestionnaire - Bornes de collecte"
        Height="560" Width="950"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:NiveauToColorConverter x:Key="NiveauToColor"/>
    </Window.Resources>

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                    Background="#2196F3" Height="45">
            <Button Content="← Retour" Width="90" Margin="8,6,0,6"
                    Background="White" Foreground="#2196F3"
                    BorderThickness="0" FontWeight="Bold"
                    Click="BtnRetour_Click"/>
            <TextBlock Text="Vue Gestionnaire — Administration"
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Liste des bornes"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <ListView x:Name="lstBornes"
                          SelectionChanged="lstBornes_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background"
                                    Value="{Binding NiveauRemplissage,
                                    Converter={StaticResource NiveauToColor}}"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Id" Width="40"
                                            DisplayMemberBinding="{Binding IdBorne}"/>
                            <GridViewColumn Header="Nom" Width="150"
                                            DisplayMemberBinding="{Binding Nom}"/>
                            <GridViewColumn Header="%" Width="50"
                                            DisplayMemberBinding="{Binding NiveauRemplissage}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>

            <Border Grid.Column="1" Margin="10,0,0,0" Padding="15"
                    BorderThickness="1" BorderBrush="#AAAAAA" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Formulaire borne"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Nom de la borne" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtNom"
                             Margin="0,0,0,12" Padding="6" Height="32"/>

                    <TextBlock Text="Adresse" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAdresse"
                             Margin="0,0,0,12" Padding="6" Height="32"/>

                    <TextBlock Text="Niveau de remplissage (0 à 100)" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtNiveau"
                             Margin="0,0,0,20" Padding="6" Height="32"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ Ajouter" Width="100" Height="34"
                                Margin="0,0,8,0"
                                Background="#4CAF50" Foreground="White"
                                BorderThickness="0"
                                Click="BtnAjouter_Click"/>
                        <Button Content="✏ Modifier" Width="100" Height="34"
                                Margin="0,0,8,0"
                                Background="#FF9800" Foreground="White"
                                BorderThickness="0"
                                Click="BtnModifier_Click"/>
                        <Button Content="🗑 Supprimer" Width="110" Height="34"
                                Background="#F44336" Foreground="White"
                                BorderThickness="0"
                                Click="BtnSupprimer_Click"/>
                    </StackPanel>

                    <Button Content="Vider le formulaire" Width="150"
                            HorizontalAlignment="Left" Height="30"
                            Click="BtnVider_Click"/>

                    <TextBlock x:Name="txtMessage"
                               Margin="0,15,0,0"
                               FontWeight="SemiBold"
                               Foreground="#2196F3"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>